local function CreateToggle(name, posY)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 30)
    btn.Position = UDim2.new(0, 10, 0, posY)
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 18
    btn.Text = name .. ": OFF"
    btn.Parent = frame
    btn.AutoButtonColor = true

    local toggled = false
    btn.MouseButton1Click:Connect(function()
        toggled = not toggled
        btn.Text = name .. (toggled and ": ON" or ": OFF")
        btn.BackgroundColor3 = toggled and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(50, 50, 50)
        if name == "Aimbot" then
            aimbotEnabled = toggled
        elseif name == "Fly" then
            flyEnabled = toggled
            if not toggled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.Velocity = Vector3.zero
            end
        elseif name == "ESP" then
            espEnabled = toggled
            for p, data in pairs(ESPs) do
                for _, line in ipairs(data.Lines) do
                    line.Visible = toggled
                end
                if BoxESPs[p] then
                    BoxESPs[p].Visible = toggled
                end
            end
        end
    end)
    return btn
end

local aimbotToggle = CreateToggle("Aimbot", 40)
local flyToggle = CreateToggle("Fly", 80)
local espToggle = CreateToggle("ESP", 120)
espToggle.Text = "ESP: ON"
espToggle.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
espEnabled = true

-- Main Render Loop
RunService.RenderStepped:Connect(function(dt)
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    crosshair.Position = center

    hue = (hue + dt * 0.3) % 1
    local rainbowColor = Color3.fromHSV(hue, 1, 1)

    for player, data in pairs(ESPs) do
        if not espEnabled or not player.Character or not IsEnemy(LocalPlayer, player) then
            for _, line in ipairs(data.Lines) do
                line.Visible = false
            end
            if BoxESPs[player] then
                BoxESPs[player].Visible = false
            end
        else
            local bones = GetBonePositions(player.Character)
            for i, connection in ipairs(data.Connections) do
                local a, b = bones[connection[1]], bones[connection[2]]
                local line = data.Lines[i]
                if a and b then
                    local a2D, aOnScreen = Camera:WorldToViewportPoint(a)
                    local b2D, bOnScreen = Camera:WorldToViewportPoint(b)
                    if aOnScreen and bOnScreen then
                        line.Visible = true
                        line.From = Vector2.new(a2D.X, a2D.Y)
                        line.To = Vector2.new(b2D.X, b2D.Y)
                        line.Color = rainbowColor
                    else
                        line.Visible = false
                    end
                else
                    line.Visible = false
                end
            end

            local box = BoxESPs[player]
            if box then
                local pos2D, width, height = GetBoundingBox2D(player.Character)
                if pos2D and width > 0 and height > 0 then
                    box.Visible = true
                    box.Position = pos2D
                    box.Size = Vector2.new(width, height)
                    box.Color = rainbowColor
                else
                    box.Visible = false
                end
            end
        end
    end

    if aimbotEnabled then
        local closest, dist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and IsEnemy(LocalPlayer, plr) and plr.Character and plr.Character:FindFirstChild("Head") then
                local head = plr.Character.Head
                local screen, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local mousePos = UserInputService:GetMouseLocation()
                    local diff = (Vector2.new(screen.X, screen.Y) - Vector2.new(mousePos.X, mousePos.Y)).Magnitude
                    if diff < dist then
                        closest = plr
                        dist = diff
                    end
                end
            end
        end
        if closest and closest.Character then
            local head = closest.Character:FindFirstChild("Head")
            if head then
                local dir = (head.Position - Camera.CFrame.Position).Unit
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + dir)
                AutoShot()
            end
        end
    end

    if flyEnabled then
        FlyStep()
    end
end)
